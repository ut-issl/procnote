#!/bin/sh
set -eu

launcher=$0
while [ -L "$launcher" ]; do
  launcher_dir=$(CDPATH= cd -P "$(dirname "$launcher")" && pwd)
  target=$(readlink "$launcher")
  case $target in
    /*) launcher=$target ;;
    *) launcher=$launcher_dir/$target ;;
  esac
done

launcher_dir=$(CDPATH= cd -P "$(dirname "$launcher")" && pwd)
gui=$launcher_dir/procnote-gui

if [ ! -x "$gui" ]; then
  printf 'procnote: application executable not found: %s\n' "$gui" >&2
  exit 1
fi

nohup "$gui" "$@" </dev/null >/dev/null 2>&1 &
